---
import Layout from "@/layouts/Layout.astro"

import AboutMe from "@/components/AboutMe.astro"
import CodeIcon from "@/components/icons/Code.astro"
import ProfileCheck from "@/components/icons/ProfileCheck.astro"
import Projects from "@/components/Projects.astro"
import SectionContainer from "@/components/SectionContainer.astro"
import Hero from "@/components/Hero.astro"
import TitleSection from "@/components/TitleSection.astro"
import Skills from "@/components/Skills.astro"
import Brain from "@/components/icons/Brain.astro"
import Contact from "@/components/Contact.astro"
import Mail from "@/components/icons/Mail.astro"
---

<Layout
  title="Porfolio de Rodriguez Lucas - Tecnico en programacion informatica"
  description="Contrata a Rodriguez Lucas con conocimientos en desarrollo full-stack junior, con experiencia en proyectos personales y habilidades en tecnologías como TypeScript, React, Angular, PostgresSQL, Kotlin y mas. ¡Descubre cómo puedo contribuir a tu equipo!"
>
  <main class="px-4">
    <SectionContainer class="py-16 md:py-36" id="inicio">
      <Hero>
      </slot>
    </Hero>
    </SectionContainer>

    <div class="space-y-24">
    <SectionContainer id="habilidades">
      <TitleSection>
        <Brain class="size-7" />
        Habilidades
      </TitleSection>
      <Skills />
    </SectionContainer>

    <SectionContainer id="proyectos">
      <TitleSection>
        <CodeIcon class="size-7" />
        Proyectos
      </TitleSection>
      <Projects />
    </SectionContainer>

    <SectionContainer id="sobre-mi">
      <TitleSection>
        <ProfileCheck class="size-7" />
        Sobre mí
      </TitleSection>
      <AboutMe />
    </SectionContainer>

    <SectionContainer id="contacto">
      <TitleSection>
        <Mail class="size-7" />
        Contacto
      </TitleSection>
      <Contact />
    </SectionContainer>
  </div>
  </main>
</Layout>
